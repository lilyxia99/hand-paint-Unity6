<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- Voice detection: Microphone access for VoiceDetector -->
  <uses-permission android:name="android.permission.RECORD_AUDIO" />

  <!-- Mesh export: write OBJ files to persistent storage -->
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

  <!-- Hand tracking: declare as a feature (not required, so app still installs on devices without it) -->
  <uses-feature android:name="oculus.software.handtracking" android:required="false" />
  <uses-feature android:name="com.oculus.handtracking" android:required="false" />

  <application>
    <meta-data android:name="com.oculus.handtracking.frequency" android:value="HIGH" />
    <meta-data android:name="com.oculus.handtracking.version" android:value="V2.0" />
  </application>

</manifest>
